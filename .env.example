PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/mega-port-terminal
CLIENT_URL=http://localhost:5173

# Clerk is used only on the client side pages: /register, /login, and /booking.
# Admin login and admin account creation do not use Clerk.
CLERK_PUBLISHABLE_KEY=pk_test_your_key_here
CLERK_SECRET_KEY=sk_test_your_key_here

# Local admin JWT settings.
ADMIN_JWT_SECRET=change_this_to_a_long_random_admin_secret
ADMIN_JWT_EXPIRES_IN=7d

# First local super admin account.
# The backend auto-creates this account if it is missing.
SEED_SUPER_ADMIN_ENABLED=true
SEED_SUPER_ADMIN_USERNAME=mport-admin
SEED_SUPER_ADMIN_EMAIL=mport-admin@mport.local
SEED_SUPER_ADMIN_PASSWORD=Mport_2026
SEED_SUPER_ADMIN_FIRST_NAME=Mega Port
SEED_SUPER_ADMIN_MIDDLE_NAME=
SEED_SUPER_ADMIN_LAST_NAME=Super Admin
SEED_SUPER_ADMIN_PHONE_NUMBER=
